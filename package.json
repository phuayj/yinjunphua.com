    "url": "https://github.com/phuayj/yinjunphua.com/issues"
  },
  "homepage": "https://github.com/phuayj/yinjunphua.com#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "playwright": "^1.60.0"
  }
}

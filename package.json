{
  "name": "yinjunphua.com",
  "version": "1.0.0",
  "description": "Eleventy build for yinjunphua.com",
  "main": "index.js",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('_site', { recursive: true, force: true })\"",
    "build": "npm run clean && eleventy",
    "dev": "eleventy --serve --watch",
    "start": "npm run dev",
    "test": "npm run build",
    "screenshots:home": "node scripts/screenshot-mobile.js /",
    "screenshots:research": "node scripts/screenshot-mobile.js /my-research.html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phuayj/yinjunphua.com.git"
  },
  "keywords": [],
